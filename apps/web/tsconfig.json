{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["@webgpu/types", "astro/client"]
  },
  "include": ["src/**/*", "src/**/*.astro", ".astro/types.d.ts"]
}
