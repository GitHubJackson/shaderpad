---
/**
 * /learn/* 着陆页通用布局
 */
import GoogleAnalytics from "@/components/GoogleAnalytics.astro";

interface Props {
  title: string;
  description: string;
  keywords?: string;
}

const { title, description, keywords } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <GoogleAnalytics />
  </head>
  <body>
    <header class="learn-header">
      <a href="/" class="learn-brand">ShaderPad</a>
      <nav>
        <a href="/">编辑器</a>
        <a href="/textures">贴图库</a>
        <a href="https://my-docs.com" rel="noopener">my-docs</a>
      </nav>
    </header>

    <main class="learn-main">
      <slot />
    </main>

    <footer class="learn-footer">
      <a href="/">← 返回编辑器</a>
      <span>·</span>
      <a href="https://my-docs.com" rel="noopener">my-docs</a>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg: #0a0a0f;
    --text: #e8e8ed;
    --text-muted: #9090a0;
    --accent: #5eb3ff;
    --border: #2a2a36;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    line-height: 1.7;
  }

  .learn-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 32px;
    border-bottom: 1px solid var(--border);
    background: #13131a;
  }

  .learn-brand {
    font-weight: 700;
    font-size: 18px;
    background: linear-gradient(135deg, #5eb3ff 0%, #b45eff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    text-decoration: none;
  }

  nav a {
    color: var(--text-muted);
    margin-left: 20px;
    text-decoration: none;
  }

  nav a:hover { color: var(--accent); }

  .learn-main {
    max-width: 900px;
    margin: 0 auto;
    padding: 48px 32px;
  }

  h1 {
    font-size: 32px;
    margin-bottom: 12px;
  }

  h2 {
    font-size: 22px;
    margin: 32px 0 12px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  p {
    margin: 12px 0;
    color: var(--text);
  }

  .lead {
    font-size: 17px;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  code {
    background: #1c1c26;
    padding: 2px 6px;
    border-radius: 3px;
    font-family: 'JetBrains Mono', Menlo, Consolas, monospace;
    font-size: 13px;
  }

  pre {
    background: #13131a;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px;
    margin: 12px 0;
    overflow-x: auto;
  }

  pre code {
    background: transparent;
    padding: 0;
  }

  a {
    color: var(--accent);
  }

  .learn-footer {
    text-align: center;
    padding: 24px;
    color: var(--text-muted);
    border-top: 1px solid var(--border);
    margin-top: 48px;
  }

  .learn-footer a { color: var(--text-muted); margin: 0 8px; }
</style>
