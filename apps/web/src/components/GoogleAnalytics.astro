---
/**
 * Google Analytics 4 注入组件
 *
 * 启用条件：设置 PUBLIC_GA_MEASUREMENT_ID 环境变量
 * - 本地：apps/web/.env
 * - 生产：GitHub Actions secrets → build env
 *
 * 未设置时整个组件返回空 Fragment，对站点零影响。
 */
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---
{GA_ID && (
  <Fragment>
    <script
      is:inline
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}
    />
    <script
      is:inline
      set:html={`
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '${GA_ID}');
      `}
    />
  </Fragment>
)}
